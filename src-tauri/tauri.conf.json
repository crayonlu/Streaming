{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "streaming",
  "version": "0.2.1",
  "identifier": "xyz.cyncyn.streaming",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Streaming",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": false,
        "shadow": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
